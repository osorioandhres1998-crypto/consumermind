# ConsumerMind — frontend (Next.js). Copia a .env.local y rellena.
# Aquí NO hay secretos de Claude; la API key vive solo en el backend.

# URL del backend Express (server-to-server; no es NEXT_PUBLIC).
API_URL=http://localhost:3001

# Secreto de NextAuth (genera uno: `npx auth secret` o una cadena larga aleatoria).
AUTH_SECRET=cambia-esto-por-un-secreto-largo-y-aleatorio
AUTH_TRUST_HOST=true
