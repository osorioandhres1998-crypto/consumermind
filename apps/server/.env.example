# ConsumerMind — backend. Copia este archivo a .env y rellena los valores.
# La ANTHROPIC_API_KEY vive SOLO aquí (servidor). Nunca en el frontend.

ANTHROPIC_API_KEY=sk-ant-REEMPLAZA_CON_TU_CLAVE
CONSUMERMIND_MODEL=claude-sonnet-4-6

# PostgreSQL
DATABASE_URL=postgres://consumermind:consumermind@localhost:5432/consumermind

# Auth: secreto para firmar/verificar los JWT del backend (genera uno largo y aleatorio)
BACKEND_JWT_SECRET=cambia-esto-por-un-secreto-largo-y-aleatorio
BACKEND_JWT_TTL=7d

# Servidor
PORT=3001
WEB_ORIGIN=http://localhost:3000
